    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Quality of care and guideline adoption score in different structural settings as assessed by an opportunity-based quality indicator (QI) composite endpoint",
          "description": "Quality of care and guideline adoption score in different structural settings as assessed by an opportunity-based QI composite endpoint defined by the number of times each of secondary endpoints has been accomplished divided by chances to accomplish them as average per center type.\n\nTo describe the quality of Heart Failure (HF) patient care in Heart Failure Unit (HFU) and non-HFU centers utilizing QIs as suggested by the 2021 European Society of Cardiology HF guideline.",
          "timeFrame": "6 months"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "Proportion of sites with a dedicated multidisciplinary team to manage patients with HF",
          "description": "To describe the structural framework of the participating centers.",
          "timeFrame": "Baseline"
        },
        {
          "measure": "Percentage of sites with dedicated trained healthcare professionals to deliver HF specific education to facilitate patient self-care.",
          "description": "To describe the structural framework of the participating centers.",
          "timeFrame": "Baseline"
        },
        {
          "measure": "(A) Proportion of patients with HF who have a documentation of their HF clinical type",
          "description": "HF clinical type: Heart failure with reduced ejection fraction (HFrEF), HF with a midrange ejection fraction (HFmrEF), HF with preserved ejection fraction (HFpEF).\n\nTo describe the patient assessment in different types of HFU and non-HFU centers.",
          "timeFrame": "Baseline"
        },
        {
          "measure": "(B) Proportion of patients with a documentation of their electrocardiogram findings",
          "description": "To describe the patient assessment in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "(C) Proportion of patients who have their natriuretic peptides (NPs) measured (within a 3-month period from the time of decompensation)",
          "description": "To describe the patient assessment in different types of HFU and non-HFU centers.",
          "timeFrame": "3 months"
        },
        {
          "measure": "(D) Proportion of patients who have their blood tests documented",
          "description": "To describe the patient assessment in different types of HFU and non-HFU centers.",
          "timeFrame": "3 months"
        },
        {
          "measure": "(E) Proportion of patients hospitalized with HF who have been referred for a cardiac rehabilitation program",
          "description": "To describe the patient assessment in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "(F) Proportion of patients hospitalized with HF who have a follow-up review by a healthcare professional within 4 weeks of hospital discharge",
          "description": "To describe the patient assessment in different types of HFU and non-HFU centers.",
          "timeFrame": "4 weeks"
        },
        {
          "measure": "(G) Proportion of patients treated with beta-blocker bisoprolol, carvedilol, sustained-release metoprolol succinate, or nebivolol in the absence of any contraindications as defined by Aktaa et al 2022",
          "description": "To describe the initial treatment algorithm of HFrEF patients following a decompensation in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "(H) Proportion of patients treated with an Angiotensin-converting enzymes (ACE) inhibitor, Angiotensin receptor blocker (ARB) or Angiotensin receptor-neprilysin inhibitor (ARNI) in the absence of any contraindications",
          "description": "To describe the initial treatment algorithm of HFrEF patients following a decompensation in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "(I) Proportion of patients treated with an Mineralocorticoid receptor antagonist (MRA) in the absence of any contraindications",
          "description": "To describe the initial treatment algorithm of HFrEF patients following a decompensation in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "(J) Proportion of patients treated with a Sodium-glucose co-transporter 2 (SGLT2) inhibitor in the absence of any contraindications",
          "description": "To describe the initial treatment algorithm of HFrEF patients following a decompensation in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Proportion of patients receiving ARNI instead of ACEi/ARB as first-line treatment",
          "description": "To describe the initial treatment algorithm of HFrEF patients following a decompensation in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Proportion of patients with HF who are prescribed loop diuretic therapy if they have evidence of fluid retention",
          "description": "To describe the initial treatment algorithm of HFrEF patients following a decompensation in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Time to treatment of the above 4 individual treatment classes and time to treatment with all four classes together",
          "description": "To describe the initial treatment algorithm of HFrEF patients following a decompensation in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Percentage of days covered with all four treatment classes",
          "description": "To describe the initial treatment algorithm of HFrEF patients following a decompensation in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "(K) Proportion of symptomatic patients with HFrEF in sinus rhythm with a QRS duration \u2265150ms and left bundle branch block QRS morphology and with LVEF \u226435% despite \u22653 months optimal medical therapy who are offered cardiac resynchronization therapy",
          "description": "To describe the therapy optimization in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "(L) Proportion of symptomatic patients with HF, LVEF \u226435% despite \u22653 months of optimal medical therapy, and ischemic heart disease (IHD) who are offered primary prevention implantable cardioverter defibrillator",
          "description": "To describe the therapy optimization in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Proportion of patients who have an assessment of their Health-related quality of life (HRQoL) using a validated tool",
          "description": "To describe the utilization of HRQoL assessments in different types of HFU and non-HFU centers.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Number of patients who are eligible for and have accomplished secondary endpoint g-j divided by the number of patients who are eligible for g-j",
          "description": "To describe quality of treatment utilizing an all-or-none composite QI.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Number of HF hospitalizations, stratified by bed type",
          "description": "Where a patient had multiple HF hospitalization stays, each hospitalization was counted.\n\nTo describe healthcare resource utilization in patients hospitalized with HF during 6 months follow-up.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Length of hospital stay",
          "description": "Length of hospital stay was considered as the time from admission date until discharge for each HF hospitalization.\n\nTo describe healthcare resource utilization in patients hospitalized with HF during 6 months follow-up.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Number of HF hospitalizations per patient",
          "description": "To describe healthcare resource utilization in patients hospitalized with HF during 6 months follow-up.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Number of newly implanted devices",
          "description": "implanted devices: implantable cardioverter defibrillator (ICD), Cardiac resynchronization therapy (CRT), combination of ICD and CRT (CRT-D).\n\nTo describe healthcare resource utilization in patients hospitalized with HF during 6 months follow-up.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Number of valve interventions",
          "description": "To describe healthcare resource utilization in patients hospitalized with HF during 6 months follow-up.",
          "timeFrame": "6 months"
        },
        {
          "measure": "Number of participants with medical history of selected comorbidities",
          "description": "To describe the HFrEF patient population with a recent decompensation",
          "timeFrame": "Baseline"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n1. Patients who provide written informed consent to participate in the study\n2. Male or female patients \u2265 18 years of age\n3. Patients with diagnosis of heart failure with reduced ejection fraction (HFrEF) and HF treatment according to the summaries of product characteristics (SmPCs)\n4. Decompensation event up to three months prior to inclusion\n\nExclusion Criteria:\n\n1. Simultaneous or planned participation in an interventional research study\n2. Participation in this study at another site e.g. in a HFU network\n3. Patients incapable of understanding and signing the informed consent form",
      "healthyVolunteers": false,
      "sex": "ALL",
      "minimumAge": "18 Years",
      "maximumAge": "100 Years",
      "stdAges": [
        "ADULT",
        "OLDER_ADULT"
      ],
      "studyPopulation": "Heart failure with reduced ejection fraction patients with a recent decompensation event",
      "samplingMethod": "NON_PROBABILITY_SAMPLE"
    },
